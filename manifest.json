{
  "manifest_version": 3,
  "name": "LootLink Discord Raid Sync",
  "version": "3.1.0",
  "description": "Scans visible/current Discord server raid channels for Raid-Helper events and imports them to LootLink.",
  "permissions": ["storage", "clipboardWrite"],
  "host_permissions": [
    "https://discord.com/*",
    "http://localhost:3000/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://discord.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
